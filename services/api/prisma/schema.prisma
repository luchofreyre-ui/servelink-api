model OperationalCommandWorkspace {
  id                                       String                                     @id @default(cuid())
  workspaceEngineVersion                   String                                     @default("collaborative_command_workspace_phase_d_v1")
  ownerUserId                              String
  title                                    String
  notes                                    String                                     @default("")
  handoffSummary                           String                                     @default("")
  bookmarks                                Json                                       @default("[]")
  markers                                  Json                                       @default("[]")
  linkedReplaySessionId                    String?
  linkedOlderReplaySessionId               String?
  linkedNewerReplaySessionId               String?
  createdAt                                DateTime                                   @default(now())
  updatedAt                                DateTime                                   @updatedAt
  owner                                     User                                       @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  shares         OperationalCommandWorkspaceShare[]
  timelineEvents OperationalCommandWorkspaceTimelineEvent[]
  replayReviewSessions           OperationalReplayReviewSession[]

  @@index([ownerUserId, updatedAt])
}

model OperationalCommandWorkspaceShare {
  id                                                           String                      @id @default(cuid())
  workspaceId                                                  String
  sharedWithUserId                                             String
  sharedByUserId                                               String
  createdAt                                                    DateTime                    @default(now())
  sharedBy   User                        @relation("OperationalCommandWorkspaceShare_sharedByUserIdToUser", fields: [sharedByUserId], references: [id], onDelete: Cascade)
  sharedWith User                        @relation("OperationalCommandWorkspaceShare_sharedWithUserIdToUser", fields: [sharedWithUserId], references: [id], onDelete: Cascade)
  workspace                                  OperationalCommandWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, sharedWithUserId], map: "OperationalCommandWorkspaceShare_workspaceId_sharedWithUserId_k")
  @@index([sharedWithUserId])
}

model OperationalCommandWorkspaceTimelineEvent {
  id                          String                      @id @default(cuid())
  workspaceId                 String
  actorUserId                 String
  eventKind                   String
  payloadJson                 Json                        @default("{}")
  createdAt                   DateTime                    @default(now())
  actor                        User                        @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  workspace OperationalCommandWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt], map: "OperationalCommandWorkspaceTimelineEvent_workspaceId_createdAt_")
}

