  @@index([chronologyCategory])
  @@index([graphEngineVersion, aggregateWindow, createdAt], map: "OperationalChronologyFrame_graphEngineVersion_aggregateWindow_c")
}

model OperationalChronologySemanticAlignment {
  id                       String                @id @default(cuid())
  replaySuiteEngineVersion String                @default("operational_replay_intelligence_suite_mega_a_v1")
  aggregateWindow          String                @default("as_of_now")
