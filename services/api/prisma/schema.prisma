/// Scoped per run; `incidentKey` is the stable cross-run identifier (hash of signature + surface + failure type).
model SystemTestIncident {
  id                     String   @id @default(cuid())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  runId                  String
  incidentKey            String
  /// @servelink/system-test-intelligence SYSTEM_TEST_INCIDENT_VERSION
  incidentVersion        String   @default("v1")
  displayTitle           String
  rootCauseCategory      String
  summary                String   @db.Text
  severity               String
  status                 String
  firstSeenRunId         String?
  lastSeenRunId          String?
  affectedRunCount       Int      @default(0)
  affectedFamilyCount    Int      @default(0)
  affectedFileCount      Int      @default(0)
  currentRunFamilyCount  Int      @default(0)
  currentRunFailureCount Int      @default(0)
  leadFamilyId           String?
  metadataJson           Json?

  run         SystemTestRun                        @relation(fields: [runId], references: [id], onDelete: Cascade)
  leadFamily  SystemTestFailureFamily?             @relation("IncidentLeadFamily", fields: [leadFamilyId], references: [id], onDelete: SetNull)
  memberships SystemTestIncidentFamilyMembership[]

  @@unique([runId, incidentKey])
  @@index([severity])
  @@index([status])
  @@index([updatedAt])
  @@index([runId])
}

/// Cross-run registry for stable `incidentKey` (occurrence + gap / reappearance).
model SystemTestIncidentIndex {
  id               String   @id @default(cuid())
  incidentKey      String   @unique
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @updatedAt
  firstSeenRunId   String?
  lastSeenRunId    String?
  occurrenceCount  Int      @default(0)
  /// Consecutive runs without this key before the last ingest that reset it (see pipeline).
  lastSeenGapRuns  Int      @default(0)

  @@index([lastSeenRunId])
}

/// Per-run snapshot for diffing and Phase 10 validation (lightweight audit trail).
model SystemTestIncidentSnapshot {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  incidentKey      String
  runId            String
  familyIdsJson    Json
  summary          String   @db.Text
  severity         String
  /// Gap immediately before this appearance (0 if also present in the chronologically prior run).
  gapRunsBefore    Int      @default(0)
  reappearedAfterGap Boolean @default(false)

  @@unique([incidentKey, runId])
  @@index([runId])
  @@index([incidentKey])
}

/// Deterministic operator fix track keyed by stable `incidentKey` (not DB incident id).
model SystemTestIncidentFixTrack {
  id                        String   @id @default(cuid())
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  incidentKey               String   @unique
  incidentVersion           String   @default("v1")
  primaryArea               String
  recommendedStepsJson      Json
  validationStepsJson       Json
  representativeFilesJson   Json?
  representativeFamilyKeysJson Json?
}

/// Phase 10 — operator action / workflow layer keyed by stable incidentKey.
model SystemTestIncidentAction {
  id            String                           @id @default(cuid())
  incidentKey   String                           @unique
  status        SystemTestIncidentActionStatus   @default(open)
  priority      SystemTestIncidentActionPriority @default(medium)
  ownerUserId   String?
  lastSeenRunId String?
  metadataJson  Json?
  createdAt     DateTime                         @default(now())
  updatedAt     DateTime                         @updatedAt
  resolvedAt    DateTime?

  /// pending | passed | failed — resolution validation (run-driven).
  validationState         String?
  validationLastCheckedAt DateTime?
  validationLastPassedAt  DateTime?
  validationLastFailedAt  DateTime?
  reopenedAt              DateTime?
  reopenCount             Int                              @default(0)

  /// Phase 11A — SLA + automation (notification-ready, no external delivery).
  slaPolicyHours           Int?
  slaStartedAt             DateTime?
  slaDueAt                 DateTime?
  slaStatus                String?
  slaLastEvaluatedAt       DateTime?
  slaDueSoonNotifiedAt     DateTime?
  slaOverdueNotifiedAt     DateTime?
  escalationReadyAt        DateTime?
  lastNotificationQueuedAt DateTime?

  owner          User?                           @relation("SystemTestIncidentActionOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  stepExecutions SystemTestIncidentStepExecution[]
  events         SystemTestIncidentEvent[]
  notes          SystemTestIncidentNote[]

  @@index([status])
  @@index([priority])
  @@index([ownerUserId])
  @@index([lastSeenRunId])
  @@index([status, priority])
  @@index([validationState])
  @@index([reopenedAt])
  @@index([slaStatus])
  @@index([slaDueAt])
  @@index([escalationReadyAt])
}

model SystemTestIncidentStepExecution {
  id               String                                @id @default(cuid())
  incidentActionId String
  stepIndex        Int
  status           SystemTestIncidentStepExecutionStatus @default(pending)
  notes            String?
  createdAt        DateTime                              @default(now())
  updatedAt        DateTime                              @updatedAt

  incidentAction SystemTestIncidentAction @relation(fields: [incidentActionId], references: [id], onDelete: Cascade)

  @@unique([incidentActionId, stepIndex])
  @@index([incidentActionId])
  @@index([status])
}

model SystemTestIncidentEvent {
  id               String                    @id @default(cuid())
  incidentActionId String
  incidentKey      String
  type             SystemTestIncidentEventType
  actorUserId      String?
  metadataJson     Json?
  createdAt        DateTime                  @default(now())

  incidentAction SystemTestIncidentAction @relation(fields: [incidentActionId], references: [id], onDelete: Cascade)
  actorUser      User?                    @relation("SystemTestIncidentEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([incidentActionId, createdAt])
  @@index([incidentKey, createdAt])
  @@index([type, createdAt])
}

model SystemTestIncidentNote {
  id               String   @id @default(cuid())
  incidentActionId String
  incidentKey      String
  userId           String?
  text             String   @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  incidentAction SystemTestIncidentAction @relation(fields: [incidentActionId], references: [id], onDelete: Cascade)
  user           User?                    @relation("SystemTestIncidentNoteUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([incidentActionId, createdAt])
  @@index([incidentKey, createdAt])
}

