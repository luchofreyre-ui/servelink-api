enum BookingAuthorityReviewStatus {
  auto
  reviewed
  overridden
}

enum BookingAuthorityMismatchType {
  missing_surface
  missing_problem
  missing_method
  incorrect_surface
  incorrect_problem
  incorrect_method
  over_tagging
  under_tagging
  other
}

enum BookingPaymentStatus {
  unpaid
  checkout_created
  payment_pending
  authorized
  paid
  failed
  refunded
  waived
}

/// Public funnel deposit + future balance lifecycle (see `PublicBookingDepositService`).
enum BookingPublicDepositStatus {
  deposit_required
  deposit_succeeded
  deposit_failed
  balance_pending_authorization
  balance_authorized
  balance_captured
  refunded
  cancellation_fee_retained
}

/// Remaining job balance after deposit (manual-capture PI lifecycle).
enum BookingRemainingBalancePaymentStatus {
  balance_not_required
  balance_pending_authorization
  balance_authorization_required
  balance_authorized
  balance_authorization_failed
  balance_captured
  balance_capture_failed
  balance_canceled
}

/// Stripe deposit refund bookkeeping for public-booking cancellations.
enum BookingDepositRefundStatus {
  refund_not_required
  refund_pending
  refund_succeeded
  refund_failed
}

enum BookingRecoveryStatus {
  none
  auto_adjusted
  failed
}

model Booking {
  id                    String                      @id @default(cuid())
  customerId            String
  status                BookingStatus               @default(pending_payment)
  hourlyRateCents       Int
  estimatedHours        Float
  currency                String                      @default("usd")
  stripeCheckoutSessionId String?                     @unique
  stripePaymentIntentId   String?                     @unique
  stripeCustomerId        String?
  stripeLastEventId       String?
  stripeClientSecret      String?
  scheduledStart        DateTime?
  /// Authoritative FO wall-clock reservation end (slot hold end at confirm); legacy rows may be null.
  scheduledEnd          DateTime?
  notes                 String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  foId                  String?
  /// Customer preference only; actual assignment uses `foId` after scheduling / holds.
  preferredFoId         String?
  tenantId              String                      @default("nustandard")
  geofenceRadiusMeters  Int?                        @default(100)
  siteLat               Float?
  siteLng               Float?
  lastInsideAt          DateTime                    @default(now())
  outsideSinceAt        DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  priceSubtotal         Float?
  priceTotal            Float?
  margin                Float?
  quotedSubtotal        Decimal?                    @db.Decimal(10, 2)
  quotedMargin          Decimal?                    @db.Decimal(10, 2)
  quotedTotal           Decimal?                    @db.Decimal(10, 2)
  paymentStatus         BookingPaymentStatus        @default(unpaid)
  paymentProvider       String?
  paymentReference      String?
  paymentCheckoutUrl    String?
  paymentAmountCents    Int?
  paymentCurrency       String?                     @default("usd")
  paymentAuthorizedAt   DateTime?
  paymentPaidAt         DateTime?
  paymentFailedAt       DateTime?
  paymentWaivedAt       DateTime?
  paymentMeta           Json?
  paymentIntentId       String?
  /// Stripe PaymentIntent id for the $100 public-booking deposit (distinct from full-booking PI when used).
  publicDepositPaymentIntentId String?                     @unique
  publicDepositStatus          BookingPublicDepositStatus  @default(deposit_required)
  publicDepositAmountCents     Int                         @default(10000)
  publicDepositPaidAt          DateTime?
  /// Total job estimate in cents at confirmation time (snapshot for remaining balance).
  estimatedTotalCentsSnapshot  Int?
  /// `estimatedTotalCentsSnapshot - publicDepositAmountCents` when snapshot exists.
  remainingBalanceAfterDepositCents Int?
  /// Stripe PaymentIntent for remaining balance (manual capture; distinct from deposit + checkout PIs).
  remainingBalancePaymentIntentId String?                     @unique
  remainingBalanceStatus          BookingRemainingBalancePaymentStatus @default(balance_not_required)
  remainingBalanceAuthorizedAt    DateTime?
  remainingBalanceCapturedAt      DateTime?
  remainingBalanceAuthorizationFailureReason String?
  cancellationFeeAmountCents      Int?
  cancellationFeeRetainedAt       DateTime?
  depositRefundId                 String?
  depositRefundStatus             BookingDepositRefundStatus  @default(refund_not_required)
  depositRefundedAt               DateTime?
  recoveryStatus                  BookingRecoveryStatus       @default(none)
  originalRequestedTime           DateTime?
  recoveryAttemptedAt             DateTime?
  canceledAt                      DateTime?
  canceledReason                  String?
  acceptedAt            DateTime?
  dispatchLockedAt      DateTime?
  enRouteAt             DateTime?
  billingSessions       BillingSession[]
  customer              User                        @relation(fields: [customerId], references: [id])
  fo                    FranchiseOwner?             @relation(fields: [foId], references: [id])
  addons                BookingAddon[]
  billingFinalization   BookingBillingFinalization?
  estimateSnapshot      BookingEstimateSnapshot?
  deepCleanProgram      BookingDeepCleanProgram?
  deepCleanVisitExecutions BookingDeepCleanVisitExecution[]
  deepCleanVisitCalibrations BookingDeepCleanVisitCalibration[]
  deepCleanProgramCalibration  BookingDeepCleanProgramCalibration?
  BookingEvent          BookingEvent[]
  bookingOffers         BookingOffer[]
  stripePayment         BookingStripePayment?
  disputeCases          DisputeCase[]
  locationPings         LocationPing[]
  opsAlerts             OpsAlert[]
  opsAlertRollups       OpsAlertRollup[]
  refundIntents         RefundIntent[]
  bookingSlotHolds      BookingSlotHold[]
  dispatchDecisions              DispatchDecision[]
  dispatchOperatorNotes          DispatchOperatorNote[]
  bookingDispatchControl         BookingDispatchControl?
  adminCommandCenterActivities   AdminCommandCenterActivity[]
  trustEvents                    TrustEvent[]
  payments                       Payment[]
  opsAnomalies                   OpsAnomaly[]
  recurringPlans                 RecurringPlan[]
  recurringPlanOutcome           RecurringPlanOutcome?
  knowledgeFeedback              KnowledgeFeedback[]
  bookingAuthorityResult         BookingAuthorityResult?
  bookingAuthorityMismatches     BookingAuthorityMismatch[]
  foAuthorityKnowledgeFeedbacks  FoAuthorityKnowledgeFeedback[]
  directionIntake                BookingDirectionIntake?
  estimateAccuracyAudit          EstimateAccuracyAudit?
  operationalMetadata            BookingOperationalMetadata?

  @@index([customerId])
  @@index([status])
  @@index([foId])
  @@index([status, scheduledStart])
  @@index([foId, status, scheduledStart])
  @@index([foId, scheduledStart])
  @@index([status, scheduledStart, remainingBalanceStatus])
  @@index([tenantId])
}

