enum SystemTestFamilyOperatorState {
  open
  acknowledged
  dismissed
}

/// Cross-run root-cause family (Phase 8).
model SystemTestFailureFamily {
  id                         String   @id @default(cuid())
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  familyKey                  String
  /// @servelink/system-test-intelligence SYSTEM_TEST_FAILURE_FAMILY_VERSION
  familyVersion              String   @default("v1")
  familyKind                 String   @default("layered_signature")
  displayTitle               String
  rootCauseSummary           String   @db.Text
  primaryAssertionType       String?
  primaryLocator             String?  @db.Text
  primarySelector            String?  @db.Text
  primaryRouteUrl            String?  @db.Text
  primaryActionName          String?
  primaryErrorCode           String?
  firstSeenRunId             String?
  lastSeenRunId              String?
  totalOccurrencesAcrossRuns Int      @default(0)
  affectedRunCount           Int      @default(0)
  affectedFileCount          Int      @default(0)
  /// active | quiet | resolved_candidate
  status                     String   @default("quiet")
  /// trendKind, seenInWindow stats, etc.
  metadataJson               Json?

  operatorState             SystemTestFamilyOperatorState @default(open)
  operatorStateUpdatedAt    DateTime?
  operatorStateUpdatedById  String?
  operatorStateNote         String?
  operatorStateUpdatedBy    User?                         @relation("SystemTestFamilyOperatorStateUpdatedBy", fields: [operatorStateUpdatedById], references: [id], onDelete: SetNull)

  memberships         SystemTestFailureFamilyMembership[]
