model DispatchConfig {
  id                           String               @id @default(cuid())
  version                      Int
  status                       DispatchConfigStatus
  label                        String?

  acceptancePenaltyWeight      Decimal              @db.Decimal(10, 4)
  completionPenaltyWeight      Decimal              @db.Decimal(10, 4)
  cancellationPenaltyWeight   Decimal              @db.Decimal(10, 4)
  loadPenaltyWeight            Decimal              @db.Decimal(10, 4)
  reliabilityBonusWeight       Decimal              @db.Decimal(10, 4)
  responseSpeedWeight          Decimal              @db.Decimal(10, 4)

  offerExpiryMinutes           Int
  assignedStartGraceMinutes    Int
  multiPassPenaltyStep         Decimal              @db.Decimal(10, 4)

  enableResponseSpeedWeighting Boolean              @default(true)
  enableReliabilityWeighting   Boolean              @default(true)
  allowReofferAfterExpiry      Boolean              @default(true)

  configJson                   Json
  createdByAdminUserId         String?
  publishedByAdminUserId       String?
  publishedAt                  DateTime?
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt

  publishAudits                DispatchConfigPublishAudit[]

  @@index([status, version])
}

model DispatchConfigPublishAudit {
  id                     String   @id @default(cuid())
  dispatchConfigId       String
  fromVersion            Int?
  toVersion              Int
  publishedByAdminUserId String?
  publishedAt            DateTime @default(now())

  diffSnapshot       Json
  warningsSnapshot   Json
  highlightsSnapshot Json
  publishSummary     String

  dispatchConfig DispatchConfig @relation(fields: [dispatchConfigId], references: [id], onDelete: Cascade)

  @@index([dispatchConfigId])
  @@index([publishedAt, toVersion])
}

model AdminDispatchDecision {
  id                      String                               @id @default(cuid())
  bookingId               String
  action                  AdminDispatchDecisionAction
  rationale               String
  targetFoId              String?
  submittedByUserId       String
  submittedByRole         String
  source                  String
  submittedAt             DateTime
  status                  String                               @default("accepted")
  executionStatus         AdminDispatchDecisionExecutionStatus @default(pending)
  executionMessage        String?
  executionErrorCode      String?
  executionAttemptCount   Int                                  @default(0)
  executionStartedAt      DateTime?
  executedAt              DateTime?
  executionIdempotencyKey String?
  createdAt               DateTime                             @default(now())
  updatedAt               DateTime                             @updatedAt

  @@index([bookingId, createdAt])
  @@index([submittedByUserId, createdAt])
  @@index([action, createdAt])
  @@index([executionStatus, createdAt])
}
