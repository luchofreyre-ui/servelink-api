  updatedAt                DateTime                      @updatedAt

  booking Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  program BookingDeepCleanProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([bookingId, visitNumber])
  @@index([programId])
  @@index([bookingId, executionStatus])
