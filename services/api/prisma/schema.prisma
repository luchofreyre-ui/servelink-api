/// Post-job comparison of quote-time signals vs observed outcome (estimate-accuracy feedback loop).
model EstimateAccuracyAudit {
  id                     String                       @id @default(cuid())
  bookingId              String                       @unique
  estimateInputSnapshot  Json
  estimateOutputSnapshot Json
  actualJobOutcome       Json?
  laborVariancePct       Float?
  pricingVariancePct     Float?
  effortVariancePct      Float?
  varianceReasonCodes    EstimateVarianceReasonCode[] @default([])
  crewFeedbackNote       String?                      @db.Text
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

/// Append-only FO knowledge outcome feedback tied to a booking.
model KnowledgeFeedback {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  bookingId        String
  franchiseOwnerId String

  scenarioId  String?
  sopKey      String?
  playbookKey String?

  outcome   String // worked | partial | failed
  effortActual String? // light | moderate | heavy

  timeTakenMinutes    Int?
  timeExpectedMinutes Int?

  notes String?

  booking        Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  franchiseOwner FranchiseOwner @relation(fields: [franchiseOwnerId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([franchiseOwnerId])
  @@index([scenarioId])
  @@index([sopKey])
}

/// Review-queue signal derived from knowledge feedback aggregates (threshold-based).
model KnowledgeReviewSignal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// scenario_failure_rate | sop_failure_rate | playbook_failure_rate | time_variance
  signalType String
  /// scenario | sop | playbook
  entityType String
  entityKey  String

  sampleCount            Int
  workedRate             Float?
  partialRate            Float?
  failedRate             Float?
  avgTimeVarianceMinutes Float?

  /// low | medium | high (detection uses medium/high only)
  severity String
  /// open | acknowledged | resolved
  status   String

  reason       String
  metadataJson Json?

  firstDetectedAt DateTime
  lastDetectedAt  DateTime

  acknowledgedAt       DateTime?
  resolvedAt           DateTime?
  acknowledgedByUserId String?
  resolvedByUserId     String?

  @@index([entityType, entityKey])
  @@index([status])
  @@index([signalType])
}

