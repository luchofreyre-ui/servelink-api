/// Durable pipeline job row (separate from SystemTestAutomationJob report records).
model SystemTestPipelineJob {
  id            String                         @id @default(cuid())
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt
  runId         String?
  stage         SystemTestPipelineJobStage
  status        SystemTestPipelineJobStatus    @default(queued)
  triggerSource SystemTestPipelineTriggerSource
  attemptCount  Int                            @default(0)
  maxAttempts   Int                            @default(3)
  queueJobId    String?
  parentJobId   String?
  /// Logical dedupe key (e.g. analysis:runId:version:hash); not unique across completed rows.
  dedupeKey     String?
  payloadJson   Json
  errorMessage  String?                        @db.Text
  startedAt     DateTime?
  completedAt   DateTime?

  parent   SystemTestPipelineJob?  @relation("PipelineJobChildren", fields: [parentJobId], references: [id], onDelete: SetNull)
  children SystemTestPipelineJob[] @relation("PipelineJobChildren")

  @@index([runId, createdAt])
  @@index([stage, status])
  @@index([dedupeKey])
  @@index([createdAt])
}

/// Durable record for system-test digest / alert / triage automation (Phase 5A).
model SystemTestAutomationJob {
  id                String                         @id @default(cuid())
  createdAt         DateTime                       @default(now())
  updatedAt         DateTime                       @updatedAt
  type              SystemTestAutomationJobType
  status            SystemTestAutomationJobStatus
  triggerSource     SystemTestAutomationTriggerSource
  targetRunId       String?
  baseRunId         String?
  reportKind        String
  headline          String?
  shortSummary      String?                        @db.Text
  dedupeKey         String?
  suppressionReason String?                        @db.Text
  payloadJson       Json
  generatedAt       DateTime?
  sentAt            DateTime?
  failureReason     String?                        @db.Text

  @@index([type, createdAt])
  @@index([dedupeKey, createdAt])
  @@index([status, createdAt])
}

