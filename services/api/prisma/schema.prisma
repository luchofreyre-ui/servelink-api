  createdAt        DateTime @default(now())
  incidentKey      String
  runId            String
  familyIdsJson    Json
  summary          String   @db.Text
  severity         String
  /// Gap immediately before this appearance (0 if also present in the chronologically prior run).
  gapRunsBefore    Int      @default(0)
  reappearedAfterGap Boolean @default(false)

  @@unique([incidentKey, runId])
  @@index([runId])
  @@index([incidentKey])
}

/// Deterministic operator fix track keyed by stable `incidentKey` (not DB incident id).
model SystemTestIncidentFixTrack {
  id                        String   @id @default(cuid())
