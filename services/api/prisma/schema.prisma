model OperationalReplayDiff {
  id                                                                                                 String                                  @id @default(cuid())
  replayAnalysisEngineVersion                                                                        String                                  @default("operational_replay_analysis_phase33_v1")
  aggregateWindow                                                                                    String                                  @default("as_of_now")
  diffCategory                                                                                       String
  sourceReplaySessionId                                                                              String
  comparisonReplaySessionId                                                                          String
  payloadJson                                                                                        Json                                    @default("{}")
