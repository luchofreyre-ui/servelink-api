  @@index([status, createdAt])
  @@index([anomalyType, createdAt])
  @@index([foId, createdAt])
  @@index([bookingStatus, createdAt])
  @@index([severity, createdAt])
  @@index([fingerprint])
  @@index([assignedToAdminId, status, createdAt])
