  @@index([operationalReplayDiffId])
  @@index([replayAnalysisEngineVersion, aggregateWindow, createdAt], map: "OperationalChronologyDelta_replayAnalysisEngineVersion_aggregat")
}

model OperationalChronologyFrame {
