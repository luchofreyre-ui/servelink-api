  interpretation ReplayInterpretationSnapshot?

  @@unique([sourceReplaySessionId, comparisonReplaySessionId, diffCategory], map: "OperationalReplayDiff_sourceReplaySessionId_comparisonReplaySes")
  @@index([diffCategory])
  @@index([replayAnalysisEngineVersion, aggregateWindow, createdAt], map: "OperationalReplayDiff_replayAnalysisEngineVersion_aggregateWind")
}

