enum DeepCleanCalibrationReviewStatus {
  unreviewed
  reviewed
}

/// Program-level calibration summary for reporting / filters.
model BookingDeepCleanProgramCalibration {
  id                            String   @id @default(cuid())
  bookingId                     String   @unique
  programId                     String
  programType                   String
  estimatedTotalDurationMinutes Int
  actualTotalDurationMinutes    Int?
  durationVarianceMinutes       Int?
  durationVariancePercent       Decimal? @db.Decimal(10, 2)
  totalVisits                   Int
  completedVisits             Int
  isFullyCompleted            Boolean
  hasAnyOperatorNotes         Boolean  @default(false)
  usableForCalibrationAnalysis Boolean @default(false)
  reviewStatus                DeepCleanCalibrationReviewStatus @default(unreviewed)
  reviewedAt                  DateTime?
  reviewedByUserId            String?
  reviewNote                  String?  @db.Text
  /// JSON array of string tags from the allowed deep-clean review tag list.
  reviewReasonTagsJson        Json?
  /// Copied from BookingEstimateSnapshot at sync time (estimate-time tuning version).
  deepCleanEstimatorConfigId      String?
  deepCleanEstimatorConfigVersion Int?
  deepCleanEstimatorConfigLabel   String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  booking Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  program BookingDeepCleanProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@index([isFullyCompleted])
  @@index([reviewStatus])
  @@index([deepCleanEstimatorConfigVersion], map: "DCP_calibration_estimator_version_idx")
  @@index([deepCleanEstimatorConfigVersion, usableForCalibrationAnalysis], map: "DCP_calibration_estimator_version_usable_idx")
}

