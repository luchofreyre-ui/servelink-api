  createdAt                  DateTime @default(now())

  @@index([cohortCategory])
  @@index([controlCohortEngineVersion, aggregateWindow, createdAt], map: "ControlCohortSnapshot_controlCohortEngineVersion_aggregateWindo")
}

model CounterfactualEvaluationSnapshot {
