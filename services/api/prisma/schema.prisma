model FranchiseOwner {
  id         String   @id @default(cuid())
  userId     String   @unique
  status     FoStatus @default(onboarding)
  safetyHold Boolean  @default(false)

  // Capability / matching
  teamSize             Int?
  /// Optional explicit crew range; when null, derived from `teamSize` at read time.
  minCrewSize          Int?
  preferredCrewSize    Int?
  maxCrewSize          Int?
  maxSquareFootage     Int?
  maxLaborMinutes      Int?
  maxDailyLaborMinutes Int?
  homeLat              Float?
  homeLng              Float?
  maxTravelMinutes     Int?   @default(60)
  reliabilityScore     Float? @default(0)

  /// Estimator `service_type` values this FO accepts in `FoService.matchFOs`.
  /// Empty array = intentional unrestricted (all service types); see `fo-supply-readiness.ts`.
  matchableServiceTypes String[] @default([])

  // Customer-facing profile
  displayName        String?
  photoUrl           String?
  bio                String?
