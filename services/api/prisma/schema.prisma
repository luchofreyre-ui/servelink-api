  aggregateWindow        String   @default("as_of_now")
  severity               String
  payloadJson            Json     @default("{}")
  createdAt              DateTime @default(now())

  @@index([balancingCategory, severity, createdAt], map: "OperationalBalancingSnapshot_balancingCategory_severity_created")
  @@index([balancingEngineVersion, aggregateWindow, createdAt], map: "OperationalBalancingSnapshot_balancingEngineVersion_aggregateWi")
}

model OperationalChronologyDelta {
