/// Public marketing flow capture of booking *direction* (service request / lead intent).
/// This is not a `Booking`, not payment-authorized, and not a slot reservation.
model BookingDirectionIntake {
  id            String   @id @default(cuid())
  serviceId     String
  homeSize      String
  bedrooms      String
  bathrooms     String
  pets          String   @default("")
  frequency     String
  preferredTime String
  /// Optional public-booking preference (franchise owner id); not a guarantee of assignment.
  preferredFoId String?
  /// Public deep-clean product choice: single_visit | phased_3_visit. Null when not deep clean or legacy rows.
  deepCleanProgram String?

  /// Validated questionnaire snapshot aligned with `EstimateFactorsDto` / `EstimateInput` (no silent defaults).
  estimateFactors Json?

  /// When intake flow created a schedulable booking, links back for estimate-accuracy snapshots.
  bookingId String? @unique
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  /// Lead identity from the public booking funnel (optional for legacy rows / callers).
  customerName  String?
  customerEmail String?

  source      String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  /// Structured service address from the public location step (for audit / replay).
  serviceLocationStreet String?
  serviceLocationCity   String?
  serviceLocationState  String?
  serviceLocationZip    String?
  serviceLocationUnit   String?
  /// Geocoded coordinates for team matching and booking.site* persistence.
  siteLat Float?
  siteLng Float?

  /// Append-only operational funnel echoes for anonymous `/book` milestones (server-capped).
  funnelMilestones Json?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([serviceId, createdAt])
}

