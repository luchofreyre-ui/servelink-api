  OperationalReplaySession_OperationalReplayDiff_sourceReplaySessionIdToOperationalReplaySession     OperationalReplaySession                @relation("OperationalReplayDiff_sourceReplaySessionIdToOperationalReplaySession", fields: [sourceReplaySessionId], references: [id], onDelete: Cascade)
