  assignedToAdminId String?
  slaDueAt          DateTime?
  slaBreachedAt     DateTime?
  ackedAt           DateTime?
  ackedByAdminId    String?
  ackNote           String?
  resolvedAt        DateTime?
  resolvedByAdminId String?
  resolveNote       String?
  payloadJson       String?
