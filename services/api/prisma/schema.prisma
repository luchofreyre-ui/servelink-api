model DispatchConfig {
  id                           String               @id @default(cuid())
  version                      Int
  status                       DispatchConfigStatus
  label                        String?

  acceptancePenaltyWeight      Decimal              @db.Decimal(10, 4)
  completionPenaltyWeight      Decimal              @db.Decimal(10, 4)
  cancellationPenaltyWeight   Decimal              @db.Decimal(10, 4)
  loadPenaltyWeight            Decimal              @db.Decimal(10, 4)
  reliabilityBonusWeight       Decimal              @db.Decimal(10, 4)
  responseSpeedWeight          Decimal              @db.Decimal(10, 4)

  offerExpiryMinutes           Int
  assignedStartGraceMinutes    Int
  multiPassPenaltyStep         Decimal              @db.Decimal(10, 4)

  enableResponseSpeedWeighting Boolean              @default(true)
  enableReliabilityWeighting   Boolean              @default(true)
  allowReofferAfterExpiry      Boolean              @default(true)

  configJson                   Json
  createdByAdminUserId         String?
  publishedByAdminUserId       String?
  publishedAt                  DateTime?
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt

