  submittedByUserId       String
  submittedByRole         String
  source                  String
  submittedAt             DateTime
  status                  String                               @default("accepted")
  executionStatus         AdminDispatchDecisionExecutionStatus @default(pending)
  executionMessage        String?
  executionErrorCode      String?
  executionAttemptCount   Int                                  @default(0)
  executionStartedAt      DateTime?
  executedAt              DateTime?
  executionIdempotencyKey String?
  createdAt               DateTime                             @default(now())
  updatedAt               DateTime                             @updatedAt

  @@index([bookingId, createdAt])
  @@index([submittedByUserId, createdAt])
  @@index([action, createdAt])
  @@index([executionStatus, createdAt])
}

/// Public marketing flow capture of booking *direction* (service request / lead intent).
/// This is not a `Booking`, not payment-authorized, and not a slot reservation.
model BookingDirectionIntake {
  id            String   @id @default(cuid())
  serviceId     String
  homeSize      String
  bedrooms      String
  bathrooms     String
  pets          String   @default("")
  frequency     String
  preferredTime String
  /// Public deep-clean product choice: single_visit | phased_3_visit. Null when not deep clean or legacy rows.
  deepCleanProgram String?

  /// Validated questionnaire snapshot aligned with `EstimateFactorsDto` / `EstimateInput` (no silent defaults).
  estimateFactors Json?

  /// Lead identity from the public booking funnel (optional for legacy rows / callers).
  customerName  String?
  customerEmail String?

  source      String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([serviceId, createdAt])
}

/// Append-only FO knowledge outcome feedback tied to a booking.
model KnowledgeFeedback {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  bookingId        String
  franchiseOwnerId String

  scenarioId  String?
  sopKey      String?
  playbookKey String?

  outcome   String // worked | partial | failed
  effortActual String? // light | moderate | heavy

  timeTakenMinutes    Int?
  timeExpectedMinutes Int?

  notes String?

  booking        Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  franchiseOwner FranchiseOwner @relation(fields: [franchiseOwnerId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([franchiseOwnerId])
  @@index([scenarioId])
  @@index([sopKey])
}

/// Review-queue signal derived from knowledge feedback aggregates (threshold-based).
model KnowledgeReviewSignal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// scenario_failure_rate | sop_failure_rate | playbook_failure_rate | time_variance
  signalType String
  /// scenario | sop | playbook
  entityType String
  entityKey  String

  sampleCount            Int
  workedRate             Float?
  partialRate            Float?
  failedRate             Float?
  avgTimeVarianceMinutes Float?

  /// low | medium | high (detection uses medium/high only)
  severity String
  /// open | acknowledged | resolved
  status   String

  reason       String
  metadataJson Json?

  firstDetectedAt DateTime
  lastDetectedAt  DateTime

  acknowledgedAt       DateTime?
  resolvedAt           DateTime?
  acknowledgedByUserId String?
  resolvedByUserId     String?

  @@index([entityType, entityKey])
  @@index([status])
  @@index([signalType])
}

enum RecurringPlanStatus {
  active
  paused
  canceled
}

enum RecurringCadence {
  weekly
  biweekly
  monthly
}

enum RecurringOccurrenceStatus {
  pending_generation
  booking_created
  scheduled
  completed
  skipped
  canceled
  needs_review
}

/// Customer recurring maintenance plan (snapshot-based; orchestrates occurrences).
model RecurringPlan {
  id                   String                 @id @default(cuid())
  customerId           String
  status               RecurringPlanStatus    @default(active)
  cadence              RecurringCadence
  serviceType          String
  preferredTimeWindow  String?
  preferredFoId        String?
  bookingNotes         String?
  estimateSnapshot     Json
  pricingSnapshot      Json
  intakeSnapshot       Json
  defaultAddonIds      Json
  addressSnapshot      Json
  createdFromBookingId String?
  nextAnchorAt         DateTime
  lastGeneratedAt      DateTime?
  canceledAt           DateTime?
  pausedAt             DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  customer    User                    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  occurrences RecurringOccurrence[]

  @@index([customerId, status])
  @@index([nextAnchorAt, status])
}

model RecurringOccurrence {
  id                    String                    @id @default(cuid())
  recurringPlanId       String
  sequenceNumber        Int
  targetDate            DateTime
  status                RecurringOccurrenceStatus @default(pending_generation)
  bookingId             String?
  overrideAddonIds      Json?
  overrideInstructions  String?
  overridePreferredFoId String?
  bookingSnapshot       Json?
  generationError       String?
  processingState       String                    @default("ready")
  processingAttempts    Int                       @default(0)
  lastProcessingAt      DateTime?
  processingToken       String?
  bookingFingerprint    String?
  bookingCreatedAt      DateTime?
  reconciliationState   String?                   @default("clean")
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  recurringPlan RecurringPlan @relation(fields: [recurringPlanId], references: [id], onDelete: Cascade)

  @@unique([recurringPlanId, sequenceNumber])
  @@index([recurringPlanId, status])
  @@index([targetDate, status])
  @@index([processingState, processingAttempts, status])
  @@index([bookingFingerprint])
  @@index([reconciliationState])
}

/// Generated encyclopedia review queue (pipeline intake → human review).
model EncyclopediaReviewRecord {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  surface       String?
  problem       String?
  intent        String?

  sections      Json
  internalLinks Json

  status        String   @default("pending")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
