generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  phone            String?          @unique
  passwordHash     String
  role             Role             @default(customer)
  stripeCustomerId String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  bookings         Booking[]
  franchiseOwner   FranchiseOwner?
  serviceProvider  ServiceProvider?
  refreshTokens    RefreshToken[]
}

model RefreshToken {
  id           String         @id @default(cuid())
  userId       String
  tokenHash    String         @unique
  jti          String?        @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  replacedBy   RefreshToken?  @relation("RefreshRotation", fields: [replacedById], references: [id])
  replaces     RefreshToken[] @relation("RefreshRotation")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum BookingPaymentStatus {
  none
  authorized_initial
  additional_authorization_required
  additional_authorization_pending
  additional_authorization_approved
  additional_authorization_declined
  ready_for_capture
  captured
  quote_ready
  requires_payment
  paid
  failed
}

model Booking {
  id                    String                      @id @default(cuid())
  customerId            String
  status                BookingStatus               @default(pending_payment)
  hourlyRateCents       Int
  estimatedHours        Float
  currency              String                      @default("usd")
  stripePaymentIntentId String?                     @unique
  stripeClientSecret    String?
  scheduledStart        DateTime?
  notes                 String?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  foId                  String?
  geofenceRadiusMeters  Int?                        @default(100)
  siteLat               Float?
  siteLng               Float?
  lastInsideAt          DateTime                    @default(now())
  outsideSinceAt        DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  priceSubtotal         Float?
  priceTotal            Float?
  margin                Float?
  quotedSubtotal        Decimal?                    @db.Decimal(10, 2)
  quotedMargin          Decimal?                    @db.Decimal(10, 2)
  quotedTotal           Decimal?                    @db.Decimal(10, 2)
  paymentStatus         BookingPaymentStatus        @default(none)
  paymentIntentId       String?
  acceptedAt            DateTime?
  enRouteAt             DateTime?
  billingSessions       BillingSession[]
  customer              User                        @relation(fields: [customerId], references: [id])
  fo                    FranchiseOwner?             @relation(fields: [foId], references: [id])
  addons                BookingAddon[]
  billingFinalization   BookingBillingFinalization?
  estimateSnapshot      BookingEstimateSnapshot?
  BookingEvent          BookingEvent[]
  bookingOffers         BookingOffer[]
  stripePayment         BookingStripePayment?
  disputeCases          DisputeCase[]
  locationPings         LocationPing[]
  opsAlerts             OpsAlert[]
  opsAlertRollups       OpsAlertRollup[]
  refundIntents         RefundIntent[]
  bookingSlotHolds      BookingSlotHold[]
  dispatchDecisions              DispatchDecision[]
  dispatchOperatorNotes          DispatchOperatorNote[]
  bookingDispatchControl         BookingDispatchControl?
  adminCommandCenterActivities   AdminCommandCenterActivity[]
  trustEvents                    TrustEvent[]
  payments                       Payment[]
  opsAnomalies                   OpsAnomaly[]

  @@index([customerId])
  @@index([status])
  @@index([foId])
  @@index([status, scheduledStart])
  @@index([foId, status, scheduledStart])
  @@index([foId, scheduledStart])
}

model BookingDispatchControl {
  id               String    @id @default(cuid())
  bookingId        String    @unique
  holdActive       Boolean   @default(false)
  holdReason       String?
  holdSource       String?
  holdSetByAdminId String?
  holdSetAt        DateTime?
  holdReleasedAt           DateTime?
  reviewRequired           Boolean   @default(false)
  reviewReason             String?
  reviewSource             String?
  reviewRequestedByAdminId String?
  reviewRequestedAt        DateTime?
  reviewCompletedAt        DateTime?
  workflowState            AdminBookingWorkflowState @default(open)
  commandCenterOperatorNote String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([holdActive, createdAt])
  @@index([reviewRequired, createdAt])
}

model AdminCommandCenterActivity {
  id          String   @id @default(cuid())
  bookingId   String
  actorUserId String
  actorRole   String   @default("admin")
  type        String
  summary     String
  metadata    Json?
  createdAt   DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
}

enum AdminBookingWorkflowState {
  open
  held
  in_review
  approved
  reassign_requested
}

model BookingStripePayment {
  id                    String   @id @default(cuid())
  bookingId             String   @unique
  stripePaymentIntentId String   @unique
  amountCents           Int
  currency              String   @default("usd")
  status                String
  clientSecret          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  stripeChargeId        String?  @unique
  Booking               Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
}

model DisputeCase {
  id                    String    @id @default(cuid())
  bookingId             String
  stripeDisputeId       String    @unique
  stripeChargeId        String?
  stripePaymentIntentId String?
  status                String
  reason                String?
  amount                Int?
  currency              String?
  closedAt              DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  Booking               Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([status, updatedAt])
  @@index([stripePaymentIntentId])
  @@index([stripeChargeId])
}

model RefundIntent {
  id                   String   @id @default(cuid())
  bookingId            String
  amountCents          Int?
  reason               String
  note                 String?
  status               String   @default("pending_execution")
  idempotencyKey       String   @unique
  stripeRefundId       String?
  createdByAdminUserId String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  Booking              Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([status, createdAt])
}

model BookingBillingFinalization {
  id                 String   @id @default(cuid())
  bookingId          String   @unique
  totalBillableMin   Int
  totalBillableCents Int
  minimumCents       Int      @default(10000)
  finalBillableCents Int
  idempotencyKey     String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  Booking            Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model JournalEntry {
  id             String           @id @default(cuid())
  bookingId      String?
  foId           String?
  type           JournalEntryType
  currency       String           @default("usd")
  idempotencyKey String?          @unique
  metadataJson   String?
  createdAt      DateTime         @default(now())
  disputeOutcome DisputeOutcome?
  lines          JournalLine[]

  @@index([bookingId, createdAt])
  @@index([foId, createdAt])
  @@index([type, createdAt])
  @@index([bookingId, type, createdAt])
  @@index([foId, type, createdAt])
}

model JournalLine {
  id          String        @id @default(cuid())
  entryId     String
  account     LedgerAccount
  direction   LineDirection
  amountCents Int
  createdAt   DateTime      @default(now())
  entry       JournalEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([account, createdAt])
  @@index([account, direction, createdAt])
}

model PayoutBatch {
  id                     String            @id @default(cuid())
  status                 PayoutBatchStatus @default(draft)
  currency               String            @default("usd")
  asOf                   DateTime
  executedAt             DateTime?
  executedByAdminId      String?
  idempotencyKey         String            @unique
  createdAt              DateTime          @default(now())
  executedIdempotencyKey String?           @unique
  lines                  PayoutLine[]
}

model PayoutLine {
  id          String      @id @default(cuid())
  batchId     String
  foId        String
  amountCents Int
  currency    String      @default("usd")
  createdAt   DateTime    @default(now())
  batch       PayoutBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, foId])
  @@index([batchId])
}

model BookingEstimateSnapshot {
  id                        String   @id @default(cuid())
  bookingId                 String   @unique
  estimatorVersion          String
  mode                      String
  confidence                Float
  riskPercentUncapped       Int
  riskPercentCappedForRange Int
  riskCapped                Boolean
  inputJson                 String
  outputJson                String
  createdAt                 DateTime @default(now())
  booking                   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([createdAt])
}

model StripeWebhookReceipt {
  id                    String   @id @default(cuid())
  stripeEventId         String   @unique
  type                  String
  livemode              Boolean  @default(false)
  bookingId             String?
  stripePaymentIntentId String?
  createdAt             DateTime @default(now())

  @@index([type, createdAt])
  @@index([bookingId, createdAt])
  @@index([stripePaymentIntentId, createdAt])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model LocationPing {
  id         String   @id @default(cuid())
  bookingId  String
  foId       String
  lat        Float
  lng        Float
  accuracyM  Int
  capturedAt DateTime
  receivedAt DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, receivedAt])
  @@index([foId, receivedAt])
}

model BillingSession {
  id              String    @id @default(cuid())
  bookingId       String
  foId            String
  startedAt       DateTime
  endedAt         DateTime?
  outsideSinceAt  DateTime?
  durationSec     Int?
  billableMin     Int?
  billableCents   Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  firstExitAt     DateTime?
  graceExpiresAt  DateTime?
  graceNotifiedAt DateTime?
  pendingExitAt   DateTime?
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, foId])
  @@index([bookingId, startedAt])
}

model SmsConfirmation {
  id          String    @id @default(cuid())
  code        String    @unique
  phone       String
  kind        String
  payloadJson String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  respondedAt DateTime?
  expiresAt   DateTime
  rawReply    String?
}

model BookingAddon {
  id                    String   @id @default(cuid())
  bookingId             String
  smsCode               String   @unique
  type                  String
  payloadJson           String
  status                String   @default("approved")
  createdAt             DateTime @default(now())
  currency              String   @default("usd")
  priceCents            Int
  stripePaymentIntentId String?
  booking               Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
  @@index([type])
}

model BookingEvent {
  id             String           @id @default(cuid())
  bookingId      String
  type           BookingEventType @default(STATUS_CHANGED)
  fromStatus     BookingStatus?
  toStatus       BookingStatus?
  note           String?
  idempotencyKey String?
  createdAt      DateTime         @default(now())
  Booking        Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  dispatchDecisions DispatchDecision[]

  @@unique([bookingId, idempotencyKey])
  @@index([bookingId, createdAt])
}

model BookingOffer {
  id            String             @id @default(cuid())
  bookingId     String
  foId          String
  status        BookingOfferStatus @default(offered)
  rank          Int
  offeredAt     DateTime?
  activateAt    DateTime?
  expiresAt     DateTime?
  respondedAt   DateTime?
  responseNote  String?
  dispatchRound Int                @default(1)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  booking       Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fo            FranchiseOwner     @relation(fields: [foId], references: [id], onDelete: Cascade)

  @@unique([bookingId, foId, dispatchRound])
  @@index([bookingId, createdAt])
  @@index([bookingId, status, createdAt])
  @@index([foId, status, createdAt])
  @@index([status, expiresAt])
  @@index([bookingId, dispatchRound, rank])
}

model DispatchDecision {
  id                       String                 @id @default(cuid())
  bookingId                String
  bookingEventId           String?
  trigger                  String
  triggerDetail            String?
  dispatchSequence         Int
  redispatchSequence       Int                    @default(0)
  decisionStatus           DispatchDecisionStatus
  selectedFranchiseOwnerId String?
  selectedRank             Int?
  selectedScore            Decimal?               @db.Decimal(10, 4)
  scoringVersion           String
  idempotencyKey           String?
  correlationKey           String?
  bookingStatusAtDecision  BookingStatus?
  scheduledStart           DateTime?
  estimatedDurationMin     Int?
  bookingSnapshot          Json
  decisionMeta             Json?
  createdAt                DateTime               @default(now())

  booking                  Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingEvent             BookingEvent?          @relation(fields: [bookingEventId], references: [id], onDelete: SetNull)
  candidates               DispatchDecisionCandidate[]

  @@index([bookingId, createdAt])
  @@index([bookingId, dispatchSequence])
  @@index([selectedFranchiseOwnerId])
  @@index([decisionStatus, createdAt])
}

model DispatchDecisionCandidate {
  id                  String                      @id @default(cuid())
  dispatchDecisionId  String
  franchiseOwnerId   String
  candidateStatus     DispatchCandidateStatus
  baseRank            Int?
  finalRank           Int?
  baseScore           Decimal?                    @db.Decimal(10, 4)
  finalScore          Decimal?                    @db.Decimal(10, 4)
  distanceMiles       Decimal?                    @db.Decimal(10, 2)
  foLoad              Int?
  acceptanceRate      Decimal?                    @db.Decimal(6, 4)
  completionRate      Decimal?                    @db.Decimal(6, 4)
  cancellationRate    Decimal?                    @db.Decimal(6, 4)
  acceptancePenalty   Decimal?                    @db.Decimal(10, 4)
  completionPenalty   Decimal?                    @db.Decimal(10, 4)
  cancellationPenalty Decimal?                    @db.Decimal(10, 4)
  loadPenalty         Decimal?                    @db.Decimal(10, 4)
  reliabilityBonus    Decimal?                    @db.Decimal(10, 4)
  finalPenalty        Decimal?                    @db.Decimal(10, 4)
  reasonCode          DispatchCandidateReasonCode?
  reasonDetail        String?
  eligibilitySnapshot Json?
  scoreBreakdown      Json?
  createdAt           DateTime                    @default(now())

  dispatchDecision    DispatchDecision            @relation(fields: [dispatchDecisionId], references: [id], onDelete: Cascade)
  franchiseOwner      FranchiseOwner              @relation(fields: [franchiseOwnerId], references: [id], onDelete: Cascade)

  @@index([dispatchDecisionId, candidateStatus])
  @@index([franchiseOwnerId, createdAt])
  @@index([reasonCode, createdAt])
}

model DispatchOperatorNote {
  id          String   @id @default(cuid())
  bookingId   String
  adminUserId String?
  note        String
  createdAt   DateTime @default(now())

  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([adminUserId, createdAt])
}

model BookingSlotHold {
  id        String   @id @default(cuid())
  bookingId String
  foId      String
  startAt   DateTime
  endAt     DateTime
  expiresAt DateTime
  createdAt DateTime @default(now())

  booking Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fo      FranchiseOwner @relation(fields: [foId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([foId, startAt, endAt])
  @@index([expiresAt])
  @@index([foId, expiresAt])
  @@index([foId, startAt])
}

model OpsAlert {
  id                String           @id @default(cuid())
  sourceEventId     String?          @unique
  bookingId         String?
  foId              String?
  bookingStatus     BookingStatus?
  anomalyType       OpsAnomalyType
  status            OpsAlertStatus   @default(open)
  payloadJson       String?
  ackedAt           DateTime?
  ackedByAdminId    String?
  ackNote           String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  assignedToAdminId String?
  fingerprint       String?
  firstSeenAt       DateTime         @default(now())
  lastSeenAt        DateTime         @default(now())
  occurrences       Int              @default(1)
  resolveNote       String?
  resolvedAt        DateTime?
  resolvedByAdminId String?
  severity          OpsAlertSeverity @default(warning)
  slaBreachedAt     DateTime?
  slaDueAt          DateTime?
  Booking           Booking?         @relation(fields: [bookingId], references: [id])

  @@index([bookingId, createdAt])
  @@index([status, createdAt])
  @@index([anomalyType, createdAt])
  @@index([foId, createdAt])
  @@index([bookingStatus, createdAt])
  @@index([severity, createdAt])
  @@index([fingerprint])
  @@index([assignedToAdminId, status, createdAt])
}

model OpsAlertRollup {
  id                String           @id @default(cuid())
  fingerprint       String           @unique
  anomalyType       OpsAnomalyType
  bookingId         String?
  foId              String?
  bookingStatus     BookingStatus?
  status            OpsAlertStatus   @default(open)
  severity          OpsAlertSeverity @default(warning)
  firstSeenAt       DateTime
  lastSeenAt        DateTime
  occurrences       Int              @default(1)
  assignedToAdminId String?
  slaDueAt          DateTime?
  slaBreachedAt     DateTime?
  ackedAt           DateTime?
  ackedByAdminId    String?
  ackNote           String?
  resolvedAt        DateTime?
  resolvedByAdminId String?
  resolveNote       String?
  payloadJson       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  opsAlertAudits    OpsAlertAudit[]
  Booking           Booking?         @relation(fields: [bookingId], references: [id])

  @@index([bookingId, createdAt])
  @@index([status, createdAt])
  @@index([severity, createdAt])
  @@index([anomalyType, createdAt])
  @@index([foId, createdAt])
  @@index([bookingStatus, createdAt])
  @@index([assignedToAdminId, status, createdAt])
}

model ServiceProvider {
  id     String                @id @default(cuid())
  userId String                @unique
  type   ServiceProviderType
  status ServiceProviderStatus @default(onboarding)

  displayName String?
  phone       String?
  email       String?

  reliabilityScore Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  franchiseOwner FranchiseOwner?

  @@index([status])
  @@index([type])
}

model FranchiseOwner {
  id         String   @id @default(cuid())
  userId     String   @unique
  status     FoStatus @default(onboarding)
  safetyHold Boolean  @default(false)

  // Capability / matching
  teamSize             Int?
  maxSquareFootage     Int?
  maxLaborMinutes      Int?
  maxDailyLaborMinutes Int?
  homeLat              Float?
  homeLng              Float?
  maxTravelMinutes     Int?   @default(60)
  reliabilityScore     Float? @default(0)

  // Customer-facing profile
  displayName        String?
  photoUrl           String?
  bio                String?
  yearsExperience    Int?
  completedJobsCount Int?    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  providerId String?          @unique
  provider   ServiceProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  bookings         Booking[]
  bookingOffers    BookingOffer[]
  slotHolds        BookingSlotHold[]
  dispatchStats    FranchiseOwnerDispatchStats?
  reliabilityStats FranchiseOwnerReliabilityStats?
  reputation       FranchiseOwnerReputation?
  jobTypeStats     FranchiseOwnerJobTypeStats[]
  user             User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dispatchDecisionCandidates DispatchDecisionCandidate[]
  foSchedules              FoSchedule[]
  foBlockouts              FoBlockout[]
  payouts                  Payout[]
  trustEvents              TrustEvent[]
  opsAnomalies             OpsAnomaly[]

  @@index([status])
  @@index([status, safetyHold])
  @@index([providerId])
  @@index([homeLat, homeLng])
  @@index([teamSize])
  @@index([maxTravelMinutes])
}

model FranchiseOwnerReputation {
  id String @id @default(cuid())

  foId String         @unique
  fo   FranchiseOwner @relation(fields: [foId], references: [id], onDelete: Cascade)

  reputationScore  Float            @default(0)
  reputationTier   ReputationTier   @default(B)
  reliabilityScore Float            @default(0)
  reliabilityLabel ReliabilityLabel @default(STANDARD)
  lastCalculatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reputationTier])
}

model FranchiseOwnerDispatchStats {
  foId                   String   @id
  offersSent             Int      @default(0)
  offersAccepted         Int      @default(0)
  offersRejected         Int      @default(0)
  offersExpired          Int      @default(0)
  averageResponseSeconds Float    @default(0)
  responseCount          Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  fo FranchiseOwner @relation(fields: [foId], references: [id], onDelete: Cascade)
}

model FranchiseOwnerReliabilityStats {
  foId                  String   @id
  assignmentsCount      Int      @default(0)
  completionsCount      Int      @default(0)
  cancellationsCount    Int      @default(0)
  inProgressCount       Int      @default(0)
  activeAssignedCount   Int      @default(0)
  activeInProgressCount Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  fo FranchiseOwner @relation(fields: [foId], references: [id], onDelete: Cascade)
}

model FranchiseOwnerJobTypeStats {
  id String @id @default(cuid())

  foId String
  fo   FranchiseOwner @relation(fields: [foId], references: [id], onDelete: Cascade)

  serviceType String
  jobSizeBand String?

  assignmentsCount   Int @default(0)
  completionsCount   Int @default(0)
  cancellationsCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([foId, serviceType, jobSizeBand])
  @@index([foId])
  @@index([serviceType, jobSizeBand])
}

model OpsAlertAudit {
  id                    String            @id @default(cuid())
  fingerprint           String
  action                String
  fromStatus            OpsAlertStatus?
  toStatus              OpsAlertStatus?
  fromSeverity          OpsAlertSeverity?
  toSeverity            OpsAlertSeverity?
  fromAssignedToAdminId String?
  toAssignedToAdminId   String?
  actorAdminId          String?
  createdAt             DateTime          @default(now())
  eventId               String?
  sourceEventId         String?
  opsAlertRollup        OpsAlertRollup    @relation(fields: [fingerprint], references: [fingerprint], onDelete: Cascade)

  @@index([fingerprint, createdAt])
  @@index([eventId, createdAt])
  @@index([sourceEventId, createdAt])
  @@index([fingerprint, action, createdAt])
  @@index([eventId, action, createdAt])
  @@index([sourceEventId, action, createdAt])
}

enum JournalEntryType {
  CHARGE
  REFUND
  PAYOUT
  ADJUSTMENT
  FEE
  SETTLEMENT
  DISPUTE
  DISPUTE_WITHDRAWAL
  DISPUTE_REVERSAL
  DISPUTE_LOSS
  DISPUTE_WIN
  REVENUE_RECOGNITION
}

enum DisputeOutcome {
  created
  won
  lost
  closed
}

enum LedgerAccount {
  AR_CUSTOMER
  CASH_STRIPE
  REV_PLATFORM
  LIAB_FO_PAYABLE
  LIAB_DEFERRED_REVENUE
}

enum LineDirection {
  DEBIT
  CREDIT
}

enum PayoutBatchStatus {
  draft
  executed
  void
}

enum OpsAlertStatus {
  open
  acked
}

enum OpsAnomalyType {
  INTEGRITY_REFUND_WEBHOOK_MISSING
  INTEGRITY_DISPUTE_STALE
  INTEGRITY_BILLING_SESSION_STALE
  UNKNOWN
  LEDGER_INVARIANT_VIOLATION
  PAYOUT_EXECUTION_BLOCKED
  payment_missing
  payment_mismatch
  dispatch_failed
  fo_unavailable_accept
  execution_missing_start
  execution_missing_complete
  trust_incident_spike
}

enum OpsAnomalyStatus {
  open
  acknowledged
  resolved
}

enum TrustEventType {
  start
  complete
  incident
  qc_pass
  qc_fail
