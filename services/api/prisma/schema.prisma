  primaryArea               String
  recommendedStepsJson      Json
  validationStepsJson       Json
  representativeFilesJson   Json?
  representativeFamilyKeysJson Json?
}

/// Phase 10 — operator action / workflow layer keyed by stable incidentKey.
model SystemTestIncidentAction {
  id            String                           @id @default(cuid())
  incidentKey   String                           @unique
  status        SystemTestIncidentActionStatus   @default(open)
  priority      SystemTestIncidentActionPriority @default(medium)
  ownerUserId   String?
  lastSeenRunId String?
  metadataJson  Json?
  createdAt     DateTime                         @default(now())
  updatedAt     DateTime                         @updatedAt
  resolvedAt    DateTime?

  /// pending | passed | failed — resolution validation (run-driven).
  validationState         String?
  validationLastCheckedAt DateTime?
  validationLastPassedAt  DateTime?
  validationLastFailedAt  DateTime?
  reopenedAt              DateTime?
  reopenCount             Int                              @default(0)

  /// Phase 11A — SLA + automation (notification-ready, no external delivery).
  slaPolicyHours           Int?
  slaStartedAt             DateTime?
  slaDueAt                 DateTime?
  slaStatus                String?
  slaLastEvaluatedAt       DateTime?
  slaDueSoonNotifiedAt     DateTime?
  slaOverdueNotifiedAt     DateTime?
  escalationReadyAt        DateTime?
  lastNotificationQueuedAt DateTime?

  owner          User?                           @relation("SystemTestIncidentActionOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  stepExecutions SystemTestIncidentStepExecution[]
  events         SystemTestIncidentEvent[]
  notes          SystemTestIncidentNote[]

  @@index([status])
  @@index([priority])
  @@index([ownerUserId])
  @@index([lastSeenRunId])
  @@index([status, priority])
  @@index([validationState])
  @@index([reopenedAt])
  @@index([slaStatus])
  @@index([slaDueAt])
  @@index([escalationReadyAt])
}

