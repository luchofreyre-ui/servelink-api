generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  phone            String?          @unique
  passwordHash     String
  role             Role             @default(customer)
  stripeCustomerId String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  bookings         Booking[]
  franchiseOwner   FranchiseOwner?
  serviceProvider  ServiceProvider?
  refreshTokens                   RefreshToken[]
  bookingAuthorityResultsReviewed BookingAuthorityResult[] @relation("BookingAuthorityResultReviewedBy")
  bookingAuthorityMismatchesAsActor BookingAuthorityMismatch[] @relation("BookingAuthorityMismatchActor")
  recurringPlans                   RecurringPlan[]
  systemTestIncidentActionsOwned   SystemTestIncidentAction[] @relation("SystemTestIncidentActionOwner")
  systemTestIncidentEventsAuthored SystemTestIncidentEvent[]  @relation("SystemTestIncidentEventActor")
  systemTestIncidentNotesAuthored  SystemTestIncidentNote[]   @relation("SystemTestIncidentNoteUser")
  systemTestFamilyOperatorStatesUpdated SystemTestFailureFamily[] @relation("SystemTestFamilyOperatorStateUpdatedBy")
  dispatchExceptionActionsOwned    DispatchExceptionAction[]  @relation("DispatchExceptionActionOwner")
  dispatchExceptionActionEventsAuthored DispatchExceptionActionEvent[] @relation("DispatchExceptionActionEventActor")
  dispatchExceptionActionNotesAuthored DispatchExceptionActionNote[] @relation("DispatchExceptionActionNoteUser")

  OperationalCommandWorkspace                                                              OperationalCommandWorkspace[]
  OperationalCommandWorkspaceShare_OperationalCommandWorkspaceShare_sharedByUserIdToUser   OperationalCommandWorkspaceShare[]         @relation("OperationalCommandWorkspaceShare_sharedByUserIdToUser")
  OperationalCommandWorkspaceShare_OperationalCommandWorkspaceShare_sharedWithUserIdToUser OperationalCommandWorkspaceShare[]         @relation("OperationalCommandWorkspaceShare_sharedWithUserIdToUser")
  OperationalCommandWorkspaceTimelineEvent                                                 OperationalCommandWorkspaceTimelineEvent[]
  OperationalGraphCollaborationAnnotation                                                  OperationalGraphCollaborationAnnotation[]
  OperationalOperatorPresence                                                              OperationalOperatorPresence?
  OperationalReplayReviewComment                                                           OperationalReplayReviewComment[]
  OperationalReplayReviewSession                                                           OperationalReplayReviewSession[]
}

model RefreshToken {
  id           String         @id @default(cuid())
  userId       String
  tokenHash    String         @unique
  jti          String?        @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  replacedBy   RefreshToken?  @relation("RefreshRotation", fields: [replacedById], references: [id])
  replaces     RefreshToken[] @relation("RefreshRotation")
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}



model CausalAttributionSnapshot {
  id                  String   @id @default(cuid())
  causalEngineVersion String   @default("causal_attribution_phase25_v1")
  aggregateWindow     String   @default("as_of_now")
  attributionCategory String
  attributionResult   String
  payloadJson         Json     @default("{}")
  createdAt           DateTime @default(now())

  @@index([attributionCategory, attributionResult], map: "CausalAttributionSnapshot_attributionCategory_attributionResult")
  @@index([causalEngineVersion, aggregateWindow, createdAt], map: "CausalAttributionSnapshot_causalEngineVersion_aggregateWindow_c")
}

