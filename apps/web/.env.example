# Public (browser) — Amazon Associates store ID applied to generated Amazon URLs.
# Required for attributed outbound links when products use `amazonUrl` / ASIN paths.
# See `getProductPurchaseUrl` precedence in `src/lib/products/getProductPurchaseUrl.ts`.
NEXT_PUBLIC_AMAZON_TAG=

# Google Analytics 4 — Measurement ID (browser). Loads gtag.js only when set.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
